---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Giscus from '../../components/Giscus.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await post.render();

const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

<BaseLayout title={post.data.title}>
	<article class="blog-post">
		<div class="container">
			<div class="post-header">
				<h1>{post.data.title}</h1>
				<div class="meta">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('en-us', {
							year: 'numeric',
							month: 'short',
							day: 'numeric',
						})}
					</time>
					<span class="separator">•</span>
					<span class="reading-time">{remarkPluginFrontmatter.minutesRead}</span>
				</div>
			</div>
			<hr />
			
			{toc.length > 0 && (
				<nav class="toc">
					<h2>Table of Contents</h2>
					<ul>
						{toc.map((heading) => (
							<li class={`depth-${heading.depth}`}>
								<a href={`#${heading.slug}`}>{heading.text}</a>
							</li>
						))}
					</ul>
				</nav>
			)}

			<div class="content">
				<Content />
			</div>
			
			<Giscus />
		</div>
	</article>
</BaseLayout>

<style>
	.blog-post {
		padding: 4rem 2rem;
	}

	.container {
		max-width: 800px;
		margin: 0 auto;
	}

	.post-header {
		margin-bottom: 2rem;
	}

	h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 1rem;
		color: var(--accent-color);
	}

	.separator {
		color: var(--base00);
	}

	time, .reading-time {
		font-size: 1rem;
	}

	hr {
		border: none;
		border-top: 1px solid var(--base2);
		margin-bottom: 3rem;
	}

	.toc {
		background-color: var(--section-alt);
		padding: 1.5rem;
		border-radius: 8px;
		margin-bottom: 3rem;
	}

	.toc h2 {
		font-size: 1.2rem;
		margin-top: 0;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--accent-color);
	}

	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.toc li {
		margin-bottom: 0.5rem;
	}

	.toc li.depth-3 {
		padding-left: 1.5rem;
	}

	.toc a {
		color: var(--secondary-color);
		text-decoration: none;
		font-size: 1.1rem;
		transition: color 0.2s;
	}

	.toc a:hover {
		text-decoration: underline;
	}

	.content :global(p) {
		font-size: 1.2rem;
		margin-bottom: 1.5rem;
		line-height: 1.8;
	}

	.content :global(h2) {
		font-size: 2rem;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.content :global(h3) {
		font-size: 1.5rem;
		margin-top: 1.5rem;
		margin-bottom: 1rem;
	}

	.content :global(ul),
	.content :global(ol) {
		margin-bottom: 1.5rem;
		padding-left: 2rem;
	}

	.content :global(ul) {
		list-style-type: disc;
	}

	.content :global(ol) {
		list-style-type: decimal;
	}

	.content :global(li) {
		font-size: 1.2rem;
		margin-bottom: 0.5rem;
		line-height: 1.8;
	}

	:global([data-theme='dark']) hr {
		border-color: var(--base02);
	}
</style>
