---
import { Image } from 'astro:assets';

interface TimelineEntry {
  years: string;
  company: string;
  logo?: ImageMetadata;
  darkLogo?: ImageMetadata;
  description: string;
}

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;
---

<section class="timeline">
  <div class="container">
    {entries.map((entry) => (
      <div class="timeline-item">
        <div class="years">{entry.years}</div>
        <div class="divider">
          <div class="dot"></div>
          <div class="line"></div>
        </div>
        <div class="logo-container">
          {entry.logo ? (
            <Image 
              src={entry.logo} 
              alt={`${entry.company} logo`} 
              width={64} 
              height={64} 
              class={`timeline-logo ${entry.darkLogo ? 'light-only' : ''}`} 
            />
          ) : !entry.darkLogo && (
            <div class="placeholder-logo">{entry.company[0]}</div>
          )}
          {entry.darkLogo && (
            <Image 
              src={entry.darkLogo} 
              alt={`${entry.company} logo`} 
              width={64} 
              height={64} 
              class="timeline-logo dark-only" 
            />
          )}
        </div>
        <div class="description">
          <Fragment set:html={entry.description} />
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .timeline {
    padding: 6rem 2rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .years {
    width: 160px;
    white-space: nowrap;
    text-align: right;
    color: var(--accent-color);
    font-size: 0.9rem;
    font-weight: 500;
    margin-top: 5px;
  }

  .divider {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 20px;
  }

  .dot {
    width: 10px;
    height: 10px;
    background-color: var(--base2);
    border-radius: 50%;
    z-index: 2;
    margin-top: 10px;
  }

  :global([data-theme='dark']) .dot {
    background-color: var(--base02);
  }

  .line {
    position: absolute;
    top: 20px;
    bottom: -4rem; /* Extend to connect to next item */
    width: 2px;
    background-color: var(--base2);
    z-index: 1;
  }

  :global([data-theme='dark']) .line {
    background-color: var(--base02);
  }

  .timeline-item:last-child .line {
    display: none;
  }

  .timeline-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 8px; /* Slight rounding for square logos */
    background-color: var(--base3);
    padding: 8px;
    border: 1px solid var(--base2);
  }

  :global([data-theme='dark']) .timeline-logo {
    background-color: var(--base03);
    border-color: var(--base02);
  }

  .logo-container {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .dark-only {
    display: none;
  }

  :global([data-theme='dark']) .light-only {
    display: none;
  }

  :global([data-theme='dark']) .dark-only {
    display: block;
  }

  .placeholder-logo {
    width: 100%;
    height: 100%;
    border-radius: 8px;
    background-color: var(--base3);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--base2);
    font-weight: bold;
    color: var(--base00);
    font-size: 1.5rem;
  }

  :global([data-theme='dark']) .placeholder-logo {
    background-color: var(--base03);
    border-color: var(--base02);
    color: var(--base0);
  }

  .description {
    flex: 1;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-color);
  }

  .description :global(a) {
    color: var(--text-color);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .description :global(ol) {
    margin: 1rem 0;
    padding-left: 1.2rem;
  }

  .description :global(li) {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .timeline-item {
      flex-direction: column;
      gap: 1rem;
    }

    .years {
      text-align: left;
      width: auto;
    }

    .divider {
      display: none;
    }

    .logo-container {
      width: 48px;
      height: 48px;
    }
  }
</style>
