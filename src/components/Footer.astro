---
const currentYear = new Date().getFullYear();
---

<footer>
  <p>
    &copy; {currentYear} Built by <strong>Alessio De Vito</strong> with <a href="https://astro.build/" target="_blank" rel="noopener noreferrer">Astro</a> and with the help of <a href="https://gemini.google.com/" target="_blank" rel="noopener noreferrer">Gemini</a>.
  </p>
</footer>

<style>
  footer {
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--nav-bg);
    margin-top: 4rem;
    color: var(--base01);
    font-size: 0.9rem;
  }

  footer a {
    color: var(--secondary-color);
    text-decoration: none;
    font-weight: 500;
  }

  footer a:hover {
    text-decoration: underline;
  }

  :global([data-theme='dark']) footer {
    border-top-color: var(--nav-bg);
    color: var(--base1);
  }

  :global([data-theme='dark']) footer a {
    color: var(--secondary-color);
  }
</style>
